              </component>
              <scrollpane id="291fa" binding="mainScrollPanel">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="2" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
