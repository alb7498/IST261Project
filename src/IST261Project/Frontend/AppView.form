                </constraints>
                <properties>
                  <text value="Filter"/>
                </properties>
              </component>
              <component id="28e0e" class="javax.swing.JButton" binding="buttonResetView">
                <constraints>
                  <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Clear Filter"/>
